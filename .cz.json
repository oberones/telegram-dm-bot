{
  "commitizen": {
    "name": "cz_conventional_commits",
    "tag_format": "$version",
    "version_scheme": "semver",
    "version": "0.11.1",
    "update_changelog_on_bump": true,
    "version_files": [
      "package.json:version",
      "package-lock.json:version",
      "package-lock.json:packages.:version",
      "apps/admin/package.json:version",
      "apps/server/package.json:version",
      "packages/db/package.json:version",
      "packages/domain/package.json:version",
      "packages/engine/package.json:version",
      "packages/shared/package.json:version"
    ]
  }
}