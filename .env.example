NODE_ENV=development
APP_ENV=local
PORT=3000
APP_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dungeon_master_bot
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_DELIVERY_MODE=webhook
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_WEBHOOK_URL=https://example.com/telegram/webhook
SESSION_SECRET=replace-me
COOKIE_SECURE=false
LOG_LEVEL=info
DEFAULT_RULES_VERSION=arena-v1-alpha
DISABLE_NEW_DISPUTES=false
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_BOOTSTRAP_DISPLAY_NAME=Local Admin
ADMIN_BOOTSTRAP_ROLE=super_admin
