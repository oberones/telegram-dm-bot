{
  "name": "@dm-bot/server",
  "version": "0.14.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --conditions=source --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dm-bot/db": "0.14.0",
    "@dm-bot/domain": "0.14.0",
    "@dm-bot/shared": "0.14.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
