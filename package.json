{
  "name": "dungeon-master-bot",
  "version": "0.11.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev --workspace @dm-bot/server",
    "dev:admin": "npm run dev --workspace @dm-bot/admin",
    "dev:server": "npm run dev --workspace @dm-bot/server",
    "docker:local:build": "docker compose -f compose.yaml -f compose.local.yaml build",
    "docker:local:down": "docker compose -f compose.yaml -f compose.local.yaml down -v",
    "docker:local:up": "docker compose -f compose.yaml -f compose.local.yaml up --build",
    "docker:prod:build": "docker compose -f compose.yaml -f compose.production.yaml build",
    "docker:prod:config": "docker compose -f compose.yaml -f compose.production.yaml config",
    "migrate": "npm run migrate --workspace @dm-bot/db",
    "test:db": "npm run test --workspace @dm-bot/db",
    "test:shared": "npm run test --workspace @dm-bot/shared",
    "test:server": "npm run test --workspace @dm-bot/server",
    "test:engine": "npm run test --workspace @dm-bot/engine",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
